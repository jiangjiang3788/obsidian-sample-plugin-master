{
  "name": "obsidian-sample-plugin-master",
  "version": "1.0.0",
  "scripts": {
    "dev": "vite",
    "check": "npm run lint && npm run typecheck && npm run gate",
    "gate": "npm run arch:public && npm run arch:capabilities && npm run arch:gate && npm run feature:gate && npm run di:gate && npm run dual-system:gate && npm run obsidian-leak:gate && npm run events-boundary:gate && npm run core-obsidian:gate && npm run core-public:gate && npm run shared-public:gate && npm run gate:settings-persistence && npm run di-resolve:gate && npm run modal-promise:gate && npm run selector-giant-subscription:gate && npm run theme-tree-recursion:gate && npm run theme-matrix-legacy-import:gate && npm run iconaction:gate",
    "build": "vite build && node scripts/fix-sourcemap.mjs && node -e \"const fs=require('fs');fs.copyFileSync('dist/main.js','main.js');fs.copyFileSync('dist/main.js.map','main.js.map');fs.copyFileSync('dist/styles.css','styles.css');\"",
    "test": "jest --config test/configs/jest.config.js",
    "test:watch": "jest --config test/configs/jest.config.js --watch",
    "test:coverage": "jest --config test/configs/jest.config.js --coverage",
    "test:unit": "jest --config test/configs/jest.config.js test/unit",
    "test:integration": "jest --config test/configs/jest.config.js test/integration",
    "test:performance": "jest --config test/configs/jest.config.js test/performance",
    "test:e2e": "wdio run ./test/configs/wdio.conf.mts",
    "test:e2e:no-proxy": "node test/e2e/run-e2e-no-proxy.js",
    "test:all": "npm run test && npm run test:e2e",
    "check:boundaries": "npx ts-node --project scripts/tsconfig.json scripts/check-boundaries.ts",
    "arch:gate": "node scripts/arch-gate.mjs",
    "feature:gate": "node scripts/feature-gate.mjs",
    "di:gate": "node scripts/di-gate.mjs",
    "dual-system:gate": "node scripts/dual-system-gate.mjs",
    "core-obsidian:gate": "node scripts/core-obsidian-gate.mjs",
    "core-public:gate": "node scripts/core-public-gate.mjs",
    "refactor:metrics": "node scripts/refactor-metrics.mjs",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "public-api:gate": "npm run arch:public",
    "capability:gate": "npm run arch:capabilities",
    "knip": "npx --yes knip",
    "jscpd": "npx --yes jscpd",
    "arch:public": "node scripts/public-api-gate.mjs",
    "arch:capabilities": "node scripts/capability-gate.mjs",
    "shared-public:gate": "node scripts/shared-public-gate.mjs",
    "arch:audit": "node scripts/arch-audit.mjs",
    "audit:shared-ui": "node scripts/audit-shared-ui-imports.mjs",
    "gate:settings-persistence": "node scripts/settings-persistence-gate.mjs",
    "ci": "npm run check && npm run gate && npm run build",
    "obsidian-leak:gate": "node scripts/obsidian-leak-gate.mjs",
    "events-boundary:gate": "node scripts/events-boundary-gate.mjs",
    "di-resolve:gate": "node scripts/di-resolve-gate.mjs",
    "modal-promise:gate": "node scripts/modal-promise-gate.mjs",
    "selector-giant-subscription:gate": "node scripts/selector-giant-subscription-gate.mjs",
    "selectors:coverage": "node scripts/selectors-coverage-report.mjs",
    "theme-tree-recursion:gate": "node scripts/theme-tree-recursion-gate.mjs",
    "theme-matrix-legacy-import:gate": "node scripts/theme-matrix-legacy-import-gate.mjs",
    "iconaction:gate": "node scripts/iconaction-gate.mjs",
    "typecheck:src": "tsc -p tsconfig.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit"
  },
  "dependencies": {
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "^6.38.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mui/icons-material": "^7.3.1",
    "@mui/material": "^7.2.0",
    "dayjs": "^1.11.13",
    "immer": "^10.1.1",
    "minisearch": "^7.2.0",
    "preact": "^10.26.9",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "use-immer": "^0.11.0",
    "use-sync-external-store": "^1.6.0",
    "zod": "^4.2.1",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-decorators": "^7.28.0",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/plugin-transform-class-properties": "^7.27.1",
    "@babel/preset-env": "^7.23.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@preact/preset-vite": "^2.10.2",
    "@rollup/plugin-replace": "^6.0.2",
    "@types/chai": "^5.2.2",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.12.0",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "@wdio/cli": "^9.19.2",
    "@wdio/local-runner": "^9.19.2",
    "@wdio/mocha-framework": "^9.19.2",
    "@wdio/spec-reporter": "^9.19.2",
    "babel-jest": "^29.7.0",
    "chai": "^5.3.3",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "formik": "^2.4.6",
    "glob": "^11.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "mocha": "^10.8.2",
    "obsidian": "^1.8.7",
    "obsidian-launcher": "^2.1.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "vite": "^7.0.6",
    "vite-tsconfig-paths": "^5.1.4",
    "wdio-obsidian-reporter": "^2.1.2",
    "wdio-obsidian-service": "^2.1.2"
  }
}
